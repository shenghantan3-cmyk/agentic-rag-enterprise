# Enterprise deploy (.env)

# API key auth (recommended in compose/prod). If empty, auth is disabled.
ENTERPRISE_API_KEY=

# Database
DATABASE_URL=postgresql+psycopg://enterprise:enterprise@postgres:5432/enterprise

# Qdrant (compose service)
QDRANT_URL=http://qdrant:6333

# Metrics
ENTERPRISE_METRICS_ENABLED=1

# Run Alembic migrations on container start
ENTERPRISE_RUN_MIGRATIONS=1

# Gunicorn concurrency
WEB_CONCURRENCY=2

# Logging
LOG_LEVEL=INFO

# Extra public paths without API key (comma-separated)
# ENTERPRISE_PUBLIC_PATHS=/healthz,/docs,/openapi.json,/redoc

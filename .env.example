# Enterprise deploy (.env)

# API key auth (recommended in compose/prod). If empty, auth is disabled.
ENTERPRISE_API_KEY=

# Database
DATABASE_URL=postgresql+psycopg://enterprise:enterprise@postgres:5432/enterprise

# Qdrant (compose service)
QDRANT_URL=http://qdrant:6333

# Uploads directory (must be shared between API and worker)
ENTERPRISE_UPLOAD_DIR=/var/lib/enterprise/uploads

# Redis queue backend (used by API to enqueue; used by worker to consume)
ENTERPRISE_REDIS_URL=redis://redis:6379/0
ENTERPRISE_QUEUE_NAME=enterprise

# Metrics
# If enabled, exposes GET /metrics (recommend keeping it behind X-API-Key)
ENTERPRISE_METRICS_ENABLED=1

# Run Alembic migrations on container start
ENTERPRISE_RUN_MIGRATIONS=1

# OCR fallback (for scanned PDFs without a usable text layer)
# If enabled and extracted text is below threshold, the worker calls ENTERPRISE_OCR_URL.
ENTERPRISE_OCR_ENABLED=1
ENTERPRISE_OCR_URL=http://ocr-service:8001
ENTERPRISE_OCR_TEXT_THRESHOLD=200

# OCR provider selection (newer ocr-service builds)
# - tencent (default): Tencent Cloud OCR via API (requires TENCENT_* creds)
# - paddle: legacy local PaddleOCR inside the ocr-service container
OCR_PROVIDER=tencent

# Policy: table-OCR invocation only when tables are detected.
# - 1 (default): detect tables per page; only then call Tencent TableOCR.
# - 0: always call TableOCR (more expensive; mainly for debugging).
OCR_TABLE_ONLY=1

# Guardrail: hard limit on pages sent to OCR
OCR_MAX_PAGES=20

# Render DPI used before sending pages to OCR (guardrail for cost/latency)
OCR_PAGE_DPI=200

# Tencent Cloud OCR credentials (only needed when OCR_PROVIDER=tencent)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
# Preferred name:
TENCENT_OCR_REGION=ap-guangzhou
# Backward compatible name (optional):
# TENCENT_REGION=ap-guangzhou

# Gunicorn concurrency
WEB_CONCURRENCY=2

# Logging
LOG_LEVEL=INFO

# Extra public paths without API key (comma-separated)
# ENTERPRISE_PUBLIC_PATHS=/healthz,/docs,/openapi.json,/redoc
